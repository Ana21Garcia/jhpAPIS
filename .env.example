VITE_APP_NAME="${APP_NAME}"

# ========================================
# Configuración de Autenticación y JWT
# ========================================

# Laravel Sanctum - Dominios autorizados
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:5173,127.0.0.1:3000
SANCTUM_MIDDLEWARE_SHOULD_CHECK_AGAINST_CSRF_TOKEN=true

# Frontend URL para links de recuperación de contraseña
FRONTEND_URL=http://localhost:3000

# Supabase (Opcional - para integración JWT)
SUPABASE_URL=https://project_id.supabase.co
SUPABASE_KEY=eyJhbGc...
SUPABASE_JWT_SECRET=tu_jwt_secret_aqui

# Configuración de tokens
TOKEN_EXPIRATION=3600
PASSWORD_RESET_TOKEN_EXPIRATION=86400

# Twilio (Opcional - para SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
